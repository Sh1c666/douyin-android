<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31) 备份与设备迁移规则。
     cookie（含 sessionid，账号级凭证）存在 SharedPreferences，绝不能被
     adb backup / 云备份 / 换机迁移导出。allowBackup=false 已兜底，这里再显式拒绝。 -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
